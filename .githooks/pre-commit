#!/usr/bin/env sh

GITLEAKS_BIN="gitleaks"

if ! command -v "$GITLEAKS_BIN" >/dev/null 2>&1; then
  # Windows fallback for fresh Winget installs where PATH is not reloaded yet.
  FALLBACK_BIN="/c/Users/$USERNAME/AppData/Local/Microsoft/WinGet/Packages/Gitleaks.Gitleaks_Microsoft.Winget.Source_8wekyb3d8bbwe/gitleaks.exe"
  if [ -f "$FALLBACK_BIN" ]; then
    GITLEAKS_BIN="$FALLBACK_BIN"
  else
    echo "[pre-commit] gitleaks is not installed."
    echo "[pre-commit] Install with: winget install Gitleaks.Gitleaks"
    exit 1
  fi
fi

echo "[pre-commit] Running gitleaks staged scan..."
"$GITLEAKS_BIN" protect --staged --redact
status=$?

if [ $status -ne 0 ]; then
  echo "[pre-commit] Secret scan failed. Commit blocked."
  exit $status
fi

echo "[pre-commit] Secret scan passed."
